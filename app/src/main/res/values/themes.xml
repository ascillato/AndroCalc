<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AndroCalc" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="CalcButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CalcNumberButton" parent="CalcButton">
        <item name="android:backgroundTint">@color/calc_number_button</item>
        <item name="android:textColor">@color/calc_light_text</item>
    </style>

    <style name="CalcClearButton" parent="CalcButton">
        <item name="android:backgroundTint">@color/calc_clear_button</item>
        <item name="android:textColor">@color/calc_light_text</item>
    </style>

    <style name="CalcEqualsButton" parent="CalcButton">
        <item name="android:backgroundTint">@color/calc_equals_button</item>
        <item name="android:textColor">@color/calc_light_text</item>
    </style>

    <style name="CalcOperatorButton" parent="CalcButton">
        <item name="android:backgroundTint">@color/calc_operator_button</item>
        <item name="android:textColor">@color/calc_dark_text</item>
    </style>
</resources>
