<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/calc_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnLanguageEs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="ES" />

        <Button
            android:id="@+id/btnLanguageEn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EN" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvExpression"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="end|bottom"
        android:padding="12dp"
        android:text="0"
        android:textColor="@color/calc_display_text"
        android:textSize="42sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn7"
                style="@style/CalcNumberButton" android:text="7" />
            <Button
                android:id="@+id/btn8"
                style="@style/CalcNumberButton" android:text="8" />
            <Button
                android:id="@+id/btn9"
                style="@style/CalcNumberButton" android:text="9" />
            <Button
                android:id="@+id/btnDivide"
                style="@style/CalcOperatorButton" android:text="/" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn4"
                style="@style/CalcNumberButton" android:text="4" />
            <Button
                android:id="@+id/btn5"
                style="@style/CalcNumberButton" android:text="5" />
            <Button
                android:id="@+id/btn6"
                style="@style/CalcNumberButton" android:text="6" />
            <Button
                android:id="@+id/btnMultiply"
                style="@style/CalcOperatorButton" android:text="*" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn1"
                style="@style/CalcNumberButton" android:text="1" />
            <Button
                android:id="@+id/btn2"
                style="@style/CalcNumberButton" android:text="2" />
            <Button
                android:id="@+id/btn3"
                style="@style/CalcNumberButton" android:text="3" />
            <Button
                android:id="@+id/btnMinus"
                style="@style/CalcOperatorButton" android:text="-" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnClear"
                style="@style/CalcClearButton" android:text="C" />
            <Button
                android:id="@+id/btn0"
                style="@style/CalcNumberButton" android:text="0" />
            <Button
                android:id="@+id/btnEquals"
                style="@style/CalcEqualsButton" android:text="=" />
            <Button
                android:id="@+id/btnPlus"
                style="@style/CalcOperatorButton" android:text="+" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
